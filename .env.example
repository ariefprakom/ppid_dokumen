# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=

# Database
DB_ENGINE=django.db.backends.mysql
DB_NAME=ppid_dokumen
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# SFTP / CDN
SFTP_HOST=
SFTP_PORT=22
SFTP_USERNAME=
SFTP_PASSWORD=
CDN_BASE_URL=https://cdn.ar-raniry.ac.id/ppid/DIP
CDN_ROOT_PATH=/usr/share/nginx/cdn/ppid/DIP

# Keycloak OIDC (set OIDC_ENABLED=True untuk mengaktifkan SSO)
OIDC_ENABLED=False
OIDC_KEYCLOAK_URL=https://sso.ar-raniry.ac.id
OIDC_KEYCLOAK_REALM=master
OIDC_RP_CLIENT_ID=ppid-django
OIDC_RP_CLIENT_SECRET=your-client-secret-here
OIDC_STAFF_ROLES=ppid-staff
OIDC_SUPERUSER_ROLES=ppid-admin
